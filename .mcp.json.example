{
  "mcpServers": {
    "intel-store": {
      "command": "uv",
      "args": ["--directory", "projects/intel-store", "run", "python", "-m", "intel_store.mcp_server"]
    },
    "design-system": {
      "command": "uv",
      "args": ["--directory", "projects/design-system", "run", "python", "-m", "design_system.mcp_server"]
    },
    "trend-tracker": {
      "command": "uv",
      "args": ["--directory", "projects/trend-tracker", "run", "python", "-m", "trend_tracker.mcp_server"]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
