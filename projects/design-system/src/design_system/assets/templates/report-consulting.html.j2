<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ topic }} — WTIS Report</title>
  <style>{{ css | safe }}</style>
  {{ pagedjs_script | safe }}
</head>
<body>
<div class="report-wrapper">

  <!-- ══ HEADER ══════════════════════════════════════════════════ -->
  <div class="report-header no-break">
    <span class="wtis-badge">WTIS v4.1</span>
    <h1>{{ title }}</h1>
    <div class="report-meta">
      <span>{{ date }}</span>
      {% if confidence %}
      <span class="meta-sep">|</span>
      <span>신뢰도: <strong class="confidence-{{ confidence }}">{{ confidence | upper }}</strong></span>
      {% endif %}
      {% if sources_count > 0 %}
      <span class="meta-sep">|</span>
      <span>출처 {{ sources_count }}건</span>
      {% endif %}
      <span class="meta-sep">|</span>
      <span>{{ filename }}</span>
    </div>
  </div>

  <!-- ══ BODY ════════════════════════════════════════════════════ -->
  <div class="report-body">

    <!-- ── Cover Zone (first page) ────────────────────────────── -->
    <div class="cover-zone">
      {% if executive_summary_html %}
      <div class="callout-box no-break">
        <div class="callout-title">경영진 요약</div>
        {{ executive_summary_html | safe }}
      </div>
      {% endif %}
    </div>

    <!-- ── Content Zone (page 2+) ─────────────────────────────── -->
    <div class="content-zone">
      {% for section in main_sections %}
      <div class="section-block{% if not loop.first %} section-block-break{% endif %}">
        <h2 class="section-title">
          {% if section.number %}
          <span class="section-number">{{ section.number }}</span>
          {% endif %}
          {{ section.clean_title }}
        </h2>
        <div class="section-content">
          {{ section.html | safe }}
        </div>
      </div>
      {% endfor %}
    </div>

  </div><!-- end .report-body -->

  <!-- ══ REFERENCES ═════════════════════════════════════════════ -->
  {% if references_html %}
  <div class="references-section">
    <h2>References</h2>
    {{ references_html | safe }}
  </div>
  {% endif %}

  <!-- ══ FOOTER ══════════════════════════════════════════════════ -->
  <div class="report-footer">
    {% if confidence %}
    <div class="footer-metric">
      <div class="metric-label">신뢰도</div>
      <div class="metric-value accent confidence-{{ confidence }}">
        {{ confidence | upper }}
      </div>
    </div>
    <div class="footer-divider"></div>
    {% endif %}
    <div class="footer-metric">
      <div class="metric-label">분석 기관</div>
      <div class="metric-value">LG U+</div>
    </div>
    <div class="footer-divider"></div>
    <div class="footer-metric">
      <div class="metric-label">시스템</div>
      <div class="metric-value">WTIS v4.1</div>
    </div>
    <div class="footer-divider"></div>
    <div class="footer-metric">
      <div class="metric-label">분석일</div>
      <div class="metric-value">{{ date if date else "—" }}</div>
    </div>
  </div>

</div><!-- end .report-wrapper -->
</body>
</html>
